{
  "name": "junglevpn-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev --concurrency=11",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:prod": "docker compose up --build -d && docker compose logs -f",
    "docker:client": "docker compose up --build -d web tma bot && docker compose logs -f"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.3",
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "packageManager": "pnpm@9.13.2"
}
